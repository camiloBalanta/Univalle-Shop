NODE_ENV=production

GATEWAY_SERVICE_HOST_PORT=3005
FRONTEND_HOST_PORT=5173
GATEWAY_SERVICE_PORT=3000

SEARCH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3000
PAYMENT_SERVICE_PORT=3000
ORDERS_SERVICE_PORT=3004
USERS_SERVICE_PORT=3000
RECOMMENDATION_SERVICE_PORT=3000

# Reemplaza usuario, password y cluster con tus datos reales de MongoDB Atlas.
# Recomendado: una base de datos por microservicio dentro del cluster.
SEARCH_MONGO_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/microsearch?retryWrites=true&w=majority
SEARCH_MONGO_DB_NAME=microsearch

CATALOG_MONGO_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/catalogo?retryWrites=true&w=majority

ORDERS_MONGO_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/pedidos?retryWrites=true&w=majority
ORDERS_MONGO_DB_NAME=pedidos

USERS_MONGO_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/usuarios?retryWrites=true&w=majority
USERS_MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/usuarios?retryWrites=true&w=majority

RECOMMENDATION_MONGO_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/recommendation-db?retryWrites=true&w=majority

JWT_SECRET=univalle-shop-secret
