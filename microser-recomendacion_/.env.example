# Port configuration
PORT=3000

# Node environment
NODE_ENV=development

# MongoDB configuration
MONGO_URI=mongodb://mongo:27017/recommendation-db

# Application
APP_NAME=Univalle Shop - Recommendation Service
APP_VERSION=1.0.0

# API Gateway (other microservices)
ORDER_SERVICE_URL=http://localhost:3001
CATALOG_SERVICE_URL=http://localhost:3002
USER_SERVICE_URL=http://localhost:3003

# Logging
LOG_LEVEL=debug
