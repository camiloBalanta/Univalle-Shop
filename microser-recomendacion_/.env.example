# Port configuration
PORT=3000

# Node environment
NODE_ENV=development

# MongoDB configuration
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Application
APP_NAME=Univalle Shop - Recommendation Service
APP_VERSION=1.0.0

# API Gateway (other microservices)
ORDERS_SERVICE_URL=http://localhost:3004
CATALOG_SERVICE_URL=http://localhost:3000
USERS_SERVICE_URL=http://localhost:3003

# Logging
LOG_LEVEL=debug