# Root .env for UnivalleShop Microservices
# This file contains environment variables that can override the defaults
# in docker-compose.yml

NODE_ENV=production

# API host ports
SEARCH_SERVICE_HOST_PORT=3001
CATALOG_SERVICE_HOST_PORT=3000
PAYMENT_SERVICE_HOST_PORT=3002
ORDERS_SERVICE_HOST_PORT=3004
USERS_SERVICE_HOST_PORT=3003
RECOMMENDATION_SERVICE_HOST_PORT=3006

# Internal service ports
SEARCH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3000
PAYMENT_SERVICE_PORT=3000
ORDERS_SERVICE_PORT=3004
USERS_SERVICE_PORT=3000
RECOMMENDATION_SERVICE_PORT=3000

# MongoDB connection strings
SEARCH_MONGO_URI=mongodb://search-mongo:27017/microsearch
CATALOG_MONGO_URI=mongodb://catalog-mongo:27017/catalogo
ORDERS_MONGO_URI=mongodb://orders-mongo:27017/pedidos
USERS_MONGO_URI=mongodb://users-mongo:27017/usuarios
USERS_MONGODB_URI=mongodb://users-mongo:27017/usuarios
RECOMMENDATION_MONGO_URI=mongodb://recommendation-mongo:27017/recommendation-db
